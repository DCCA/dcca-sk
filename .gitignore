.DS_Store
Thumbs.db
*.swp
*~

# Config preenchida de cada skill (dados reais da empresa nunca vao para o repo).
# Versionamos so o config.example.md; o config.md fica local.
skills/**/config.md

# Config portatil (dotfiles/): NUNCA versionar segredo nem estado local de tool.
dotfiles/*/.credentials.json
dotfiles/*/auth.json
dotfiles/*/settings.local.json
dotfiles/*/history.jsonl

# Artefatos do skills CLI (npx skills add) e estado local do Claude no repo.
# As skills externas do skills/registry sao instaladas GLOBALMENTE (~/.agents),
# nunca aqui - o install.sh roda o npx a partir do $HOME.
.agents/
skills-lock.json
.claude/
